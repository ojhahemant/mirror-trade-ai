# ═══════════════════════════════════════════
# MIRROR TRADE AI — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in values

# ── Zerodha Kite Connect ──────────────────
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_ACCESS_TOKEN=your_kite_access_token_here
KITE_REQUEST_TOKEN=

# ── Database ──────────────────────────────
POSTGRES_USER=mirrortrade
POSTGRES_PASSWORD=mirrortrade_secure_pass
POSTGRES_DB=mirrortrade_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mirrortrade:mirrortrade_secure_pass@postgres:5432/mirrortrade_db

# ── Redis ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ──────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_key_at_least_64_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Alerts ────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@mirrortradeai.com

# ── App Config ────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── ML Config ─────────────────────────────
MODEL_DIR=/app/models_saved
MIN_CONFIDENCE_BUY=65
MIN_CONFIDENCE_SELL=65
RETRAIN_SCHEDULE=0 6 * * 0

# ── Market Config ─────────────────────────
BANKNIFTY_INSTRUMENT_TOKEN=260105
BANKNIFTY_SYMBOL=NSE:BANKNIFTY
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
IST_TIMEZONE=Asia/Kolkata
